# ============================================
# CONFIGURATION — RIS Scan Pro Backend
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs

# Secret key pour signer les JWT (changez cela en production !)
# Générez une clé : openssl rand -hex 32
SECRET_KEY=changez_cette_cle_en_production_super_secrete_123456

# URL de la base de données (SQLite par défaut en dev, PostgreSQL en prod)
DATABASE_URL=sqlite:///./ris_scan_pro.db
# Pour PostgreSQL (Production): DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clés Stripe — obtenez les vôtres sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REMPLACEZ_PAR_VOTRE_CLE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_REMPLACEZ_PAR_VOTRE_SECRET_WEBHOOK

# Intelligence Artificielle
GEMINI_API_KEY=VOTRE_CLE_API_GEMINI
MISTRAL_API_KEY=VOTRE_CLE_API_MISTRAL

# URL du frontend (pour les redirections Stripe)
FRONTEND_URL=http://localhost:5173

# CORS — Origines autorisées (Séparez par des virgules)
ALLOWED_ORIGINS=http://localhost:5173,https://votre-app.vercel.app
